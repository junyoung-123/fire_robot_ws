<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fire_robot">

  <!-- ===================================================
       화재 대피 모바일 매니퓰레이터
       - 모바일 베이스 : 차동 구동(Differential Drive) 4바퀴
       - 로봇팔        : PIPER 6DoF (간략화 링크)
       - 센서          : RGB 카메라 (Intel RealSense D435 컬러)
                         Depth 카메라 (Intel RealSense D435 뎁스)
                         Radar (mmWave 2D, 240° FOV, 80m 레인지)
       =================================================== -->

  <xacro:property name="base_length"  value="0.40"/>
  <xacro:property name="base_width"   value="0.35"/>
  <xacro:property name="base_height"  value="0.12"/>
  <xacro:property name="wheel_radius" value="0.07"/>
  <xacro:property name="wheel_width"  value="0.05"/>
  <xacro:property name="base_mass"    value="15.0"/>
  <xacro:property name="wheel_mass"   value="0.5"/>

  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ============ base_footprint ============ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ============ 모바일 베이스 ============ -->
  <link name="base_link">
    <xacro:box_inertia m="${base_mass}"
                       x="${base_length}" y="${base_width}" z="${base_height}"/>
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="gray"><color rgba="0.4 0.4 0.4 1.0"/></material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- ============ 바퀴 매크로 ============ -->
  <xacro:macro name="wheel" params="name x_pos y_pos">
    <link name="${name}_wheel">
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="${x_pos} ${y_pos} ${-base_height/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="front_left"  x_pos="${base_length/2 - 0.05}" y_pos="${base_width/2 + wheel_width/2}"/>
  <xacro:wheel name="front_right" x_pos="${base_length/2 - 0.05}" y_pos="${-(base_width/2 + wheel_width/2)}"/>
  <xacro:wheel name="rear_left"   x_pos="${-(base_length/2 - 0.05)}" y_pos="${base_width/2 + wheel_width/2}"/>
  <xacro:wheel name="rear_right"  x_pos="${-(base_length/2 - 0.05)}" y_pos="${-(base_width/2 + wheel_width/2)}"/>

  <!-- ============ Radar ============ -->
  <link name="radar_link">
    <visual>
      <geometry><box size="0.06 0.04 0.02"/></geometry>
      <material name="dark_gray"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.06 0.04 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="radar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="radar_link"/>
    <origin xyz="${base_length/2} 0 ${base_height/2 + 0.01}" rpy="0 0 0"/>
  </joint>

  <!-- ============ RGB-D 카메라 마운트 ============ -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.090 0.025"/></geometry>
      <material name="silver"><color rgba="0.8 0.8 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.025 0.090 0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.072"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <!-- 베이스 전방 상단에 전방 하향 8도 틸트 -->
    <origin xyz="${base_length/2} 0 ${base_height/2 + 0.15}" rpy="0 0.14 0"/>
  </joint>

  <!-- 카메라 광학 프레임 (ROS 컨벤션: Z 앞, X 오른쪽) -->
  <link name="camera_color_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ============ Depth Camera (RealSense D435 뎁스 모듈) ============ -->
  <!-- D435의 뎁스 모듈은 컬러 모듈과 같은 하우징 내 약 17.5mm 오프셋 -->
  <link name="depth_camera_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="depth_camera_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="depth_camera_link"/>
    <origin xyz="0 -0.0175 0" rpy="0 0 0"/>
  </joint>

  <!-- Depth 광학 프레임 -->
  <link name="depth_optical_frame"/>
  <joint name="depth_optical_joint" type="fixed">
    <parent link="depth_camera_link"/>
    <child  link="depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ============ PIPER 로봇팔 (6DoF 간략화) ============ -->
  <!-- 팔 베이스를 모바일 베이스 위 중앙에 탑재 -->
  <link name="arm_base_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="arm_base_link"/>
    <origin xyz="0.05 0 ${base_height/2 + 0.03}" rpy="0 0 0"/>
  </joint>

  <!-- Joint 1 - 팔 회전 (Z축) -->
  <link name="arm_link1">
    <visual><geometry><cylinder radius="0.03" length="0.12"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material></visual>
    <collision><geometry><cylinder radius="0.03" length="0.12"/></geometry></collision>
    <xacro:cylinder_inertia m="0.4" r="0.03" h="0.12"/>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="arm_base_link"/>
    <child  link="arm_link1"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="30" velocity="1.5"/>
  </joint>

  <!-- Joint 2 - 어깨 (Y축) -->
  <link name="arm_link2">
    <visual><geometry><box size="0.06 0.04 0.25"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material></visual>
    <collision><geometry><box size="0.06 0.04 0.25"/></geometry></collision>
    <xacro:box_inertia m="0.5" x="0.06" y="0.04" z="0.25"/>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="arm_link1"/>
    <child  link="arm_link2"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.09" upper="2.09" effort="30" velocity="1.5"/>
  </joint>

  <!-- Joint 3 - 팔꿈치 (Y축) -->
  <link name="arm_link3">
    <visual><geometry><box size="0.05 0.04 0.22"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material></visual>
    <collision><geometry><box size="0.05 0.04 0.22"/></geometry></collision>
    <xacro:box_inertia m="0.4" x="0.05" y="0.04" z="0.22"/>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="arm_link2"/>
    <child  link="arm_link3"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.44" upper="2.44" effort="20" velocity="1.5"/>
  </joint>

  <!-- Joint 4 - 손목 Roll (X축) -->
  <link name="arm_link4">
    <visual><geometry><cylinder radius="0.025" length="0.10"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material></visual>
    <collision><geometry><cylinder radius="0.025" length="0.10"/></geometry></collision>
    <xacro:cylinder_inertia m="0.2" r="0.025" h="0.10"/>
  </link>
  <joint name="joint4" type="revolute">
    <parent link="arm_link3"/>
    <child  link="arm_link4"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2.0"/>
  </joint>

  <!-- Joint 5 - 손목 Pitch (Y축) -->
  <link name="arm_link5">
    <visual><geometry><cylinder radius="0.025" length="0.09"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material></visual>
    <collision><geometry><cylinder radius="0.025" length="0.09"/></geometry></collision>
    <xacro:cylinder_inertia m="0.2" r="0.025" h="0.09"/>
  </link>
  <joint name="joint5" type="revolute">
    <parent link="arm_link4"/>
    <child  link="arm_link5"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="2.0"/>
  </joint>

  <!-- Joint 6 - 손목 Yaw (Z축) -->
  <link name="arm_link6">
    <visual><geometry><cylinder radius="0.02" length="0.07"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material></visual>
    <collision><geometry><cylinder radius="0.02" length="0.07"/></geometry></collision>
    <xacro:cylinder_inertia m="0.15" r="0.02" h="0.07"/>
  </link>
  <joint name="joint6" type="revolute">
    <parent link="arm_link5"/>
    <child  link="arm_link6"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="5" velocity="2.0"/>
  </joint>

  <!-- ============ 그리퍼 ============ -->
  <link name="gripper_base_link">
    <visual><geometry><box size="0.04 0.07 0.04"/></geometry>
      <material name="silver"><color rgba="0.8 0.8 0.8 1.0"/></material></visual>
    <collision><geometry><box size="0.04 0.07 0.04"/></geometry></collision>
    <xacro:box_inertia m="0.1" x="0.04" y="0.07" z="0.04"/>
  </link>
  <joint name="gripper_base_joint" type="fixed">
    <parent link="arm_link6"/>
    <child  link="gripper_base_link"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </joint>

  <link name="gripper_finger_left">
    <visual><geometry><box size="0.015 0.01 0.06"/></geometry>
      <material name="silver"><color rgba="0.8 0.8 0.8 1.0"/></material></visual>
    <collision><geometry><box size="0.015 0.01 0.06"/></geometry></collision>
    <xacro:box_inertia m="0.02" x="0.015" y="0.01" z="0.06"/>
  </link>
  <joint name="gripper_left_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child  link="gripper_finger_left"/>
    <origin xyz="0 0.025 0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="5" velocity="0.1"/>
  </joint>

  <link name="gripper_finger_right">
    <visual><geometry><box size="0.015 0.01 0.06"/></geometry>
      <material name="silver"><color rgba="0.8 0.8 0.8 1.0"/></material></visual>
    <collision><geometry><box size="0.015 0.01 0.06"/></geometry></collision>
    <xacro:box_inertia m="0.02" x="0.015" y="0.01" z="0.06"/>
  </link>
  <joint name="gripper_right_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child  link="gripper_finger_right"/>
    <origin xyz="0 -0.025 0.03" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.04" effort="5" velocity="0.1"/>
  </joint>

  <!-- ============ Gazebo Ignition 플러그인 ============ -->

  <!-- Radar (Ignition gpu_lidar: 240° FOV, 80m, /scan 토픽 → Nav2 호환) -->
  <gazebo reference="radar_link">
    <sensor name="radar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>20</update_rate>
      <topic>scan</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>500</samples>
            <resolution>1</resolution>
            <min_angle>-2.094</min_angle>
            <max_angle>2.094</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.5</min>
          <max>80.0</max>
          <resolution>0.05</resolution>
        </range>
        <noise type="gaussian">
          <mean>0.0</mean>
          <stddev>0.05</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- RGB 카메라 (Ignition camera 센서) -->
  <gazebo reference="camera_link">
    <sensor name="rgb_camera" type="camera">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30</update_rate>
      <topic>camera_raw</topic>
      <camera name="rgb">
        <horizontal_fov>1.204</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
    </sensor>
  </gazebo>

  <!-- Depth Camera (Ignition rgbd_camera: RGB + Depth + PointCloud) -->
  <gazebo reference="depth_camera_link">
    <sensor name="depth_camera" type="rgbd_camera">
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>30</update_rate>
      <topic>depth_camera</topic>
      <camera name="depth">
        <horizontal_fov>1.204</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.003</stddev>
        </noise>
      </camera>
    </sensor>
  </gazebo>

  <!-- 차동 구동 (Ignition DiffDrive 시스템) -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <!-- wheel_separation = 2 × (base_width/2 + wheel_width/2) = 0.40 m -->
      <wheel_separation>0.40</wheel_separation>
      <wheel_radius>0.07</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <max_linear_acceleration>1.0</max_linear_acceleration>
    </plugin>
  </gazebo>

  <!-- 조인트 상태 발행 (Ignition JointStatePublisher 시스템) -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

</robot>
